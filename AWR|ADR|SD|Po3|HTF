Helper helper = Helper.new()
var Trace trace = Trace.new()
color color_transparent = #ffffff00

method LineStyle(Helper h, string style) =>
    h.name := style
    switch style
        '----' => line.style_dashed
        '····' => line.style_dotted
        =>        line.style_solid

method ValidTimeframe(Helper h, string HTF) =>
    h.name := HTF
    if timeframe.in_seconds(HTF) >= timeframe.in_seconds('D') and timeframe.in_seconds(HTF) > timeframe.in_seconds()
        false
    else
        n1 = timeframe.in_seconds() 
        n2 = timeframe.in_seconds(HTF)
        n1 < n2 and math.round(n2/n1) == n2/n1

method RemainingTime(Helper h, string HTF) =>
    h.name := HTF
    if barstate.isrealtime
        tr = (time_close(HTF) - timenow) / 1000
        d = math.floor(tr/86400) 
        hh = math.floor((tr - d*86400)/3600)
        m = math.floor((tr - d*86400 - hh*3600)/60) 
        s = math.floor(tr - d*86400 - hh*3600 - m*60)
        r = str.tostring(s,'00')
        if m > 0 or hh > 0 or d > 0 
            r := str.tostring(m,'00')+':'+r
        if hh > 0 or d > 0          
            r := str.tostring(hh,'00')+':'+r
        if d > 0                    
            r := str.tostring(d)+'D '+r
        r
    else
        'n/a'

method HTFName(Helper h, string HTF) =>
    h.name := 'HTFName'
    sec = timeframe.in_seconds(HTF)
    sec < 60    ? str.tostring(sec)+'s' :
     sec/60 < 60 ? str.tostring(sec/60)+'m' :
     sec/3600 < 24 ? str.tostring(sec/3600)+'H' : HTF

method HTFEnabled(Helper h) =>
    h.name := 'HTFEnabled'
    cnt = (htf1.settings.show ? 1 : 0) + (htf2.settings.show ? 1 : 0) + (htf3.settings.show ? 1 : 0) + (htf4.settings.show ? 1 : 0) + (htf5.settings.show ? 1 : 0) + (htf6.settings.show ? 1 : 0)
    math.min(cnt, settings.max_sets)

method CandleSetHigh(Helper h, array<Candle> candles, float hi) =>
    h.name := 'CandleSetHigh'
    _h = hi
    if candles.size() > 0
        for i = 0 to candles.size()-1
            c = candles.get(i)
            if c.h > _h 
                _h := c.h
    _h

method CandlesHigh(Helper h, array<Candle> candles) =>
    h.name := 'CandlesHigh'
    hi = 0.0 
    cnt = 0 
    last = h.HTFEnabled()
    if htf1.settings.show and h.ValidTimeframe(htf1.settings.htf) 
        hi := h.CandleSetHigh(htf1.candles, hi) 
        cnt += 1
    if htf2.settings.show and h.ValidTimeframe(htf2.settings.htf) and cnt < last 
        hi := h.CandleSetHigh(htf2.candles, hi) 
        cnt += 1
    if htf3.settings.show and h.ValidTimeframe(htf3.settings.htf) and cnt < last 
        hi := h.CandleSetHigh(htf3.candles, hi) 
        cnt += 1
    if htf4.settings.show and h.ValidTimeframe(htf4.settings.htf) and cnt < last 
        hi := h.CandleSetHigh(htf4.candles, hi) 
        cnt += 1
    if htf5.settings.show and h.ValidTimeframe(htf5.settings.htf) and cnt < last 
        hi := h.CandleSetHigh(htf5.candles, hi) 
        cnt += 1
    if htf6.settings.show and h.ValidTimeframe(htf6.settings.htf) and cnt < last 
        hi := h.CandleSetHigh(htf6.candles, hi)
    hi

method Reorder(CandleSet cs, int offset) =>
    sz = cs.candles.size()
    if sz > 0
        for i = sz - 1 to 0
            c = cs.candles.get(i)
            tb = offset + (settings.width + settings.buffer) * (sz - i - 1)
            c.body.set_left(bar_index + tb) 
            c.body.set_right(bar_index + settings.width + tb)
            c.wick_up.set_x1(bar_index + settings.width/2 + tb) 
            c.wick_up.set_x2(bar_index + settings.width/2 + tb)
            c.wick_down.set_x1(bar_index + settings.width/2 + tb) 
            c.wick_down.set_x2(bar_index + settings.width/2 + tb)
    top  = helper.CandlesHigh(cs.candles)
    left = bar_index + offset + (settings.width + settings.buffer) * (sz - 1) / 2
    if settings.htf_label_show
        lbl_str = helper.HTFName(cs.settings.htf)
        if not na(cs.tfName) 
            label.set_xy(cs.tfName, left, top)
        else                 
            cs.tfName := label.new(left, top, lbl_str, color=color_transparent, textcolor=settings.htf_label_color, style=label.style_label_down, size=settings.htf_label_size)
    if settings.htf_timer_show
        tmr = '('+helper.RemainingTime(cs.settings.htf)+')'
        if not na(cs.tfTimer) 
            label.set_xy(cs.tfTimer, left, top)
        else                  
            cs.tfTimer := label.new(left, top, tmr, color=color_transparent, textcolor=settings.htf_timer_color, style=label.style_label_down, size=settings.htf_timer_size)
    cs

method FindImbalance(CandleSet cs) =>
    if barstate.isrealtime or barstate.islast
        if cs.imbalances.size() > 0
            for i = cs.imbalances.size() - 1 to 0
                cs.imbalances.get(i).b.delete()
            cs.imbalances.clear()
        if cs.candles.size() > 2 and settings.vi_show
            for i = 1 to cs.candles.size() - 2
                c1 = cs.candles.get(i) 
                c2 = cs.candles.get(i+1)
                if c1.l < c2.h and math.min(c1.o,c1.c) > math.max(c2.o,c2.c)
                    imb = Imbalance.new()
                    imb.b := box.new(c2.body.get_left(), math.min(c1.o,c1.c), c1.body.get_right(), math.max(c2.o,c2.c), bgcolor=settings.vi_color, border_color=color_transparent)
                    cs.imbalances.push(imb)
                if c1.h > c2.l and math.max(c1.o,c1.c) < math.min(c2.o,c2.c)
                    imb = Imbalance.new()
                    imb.b := box.new(c1.body.get_right(), math.min(c2.o,c2.c), c2.body.get_left(), math.max(c1.o,c1.c), bgcolor=settings.vi_color, border_color=color_transparent)
                    cs.imbalances.push(imb)
    cs

method Monitor(CandleSet cs) =>
    HTFBarTime    = time(cs.settings.htf)
    isNewHTFCandle = ta.change(HTFBarTime)
    if bool(isNewHTFCandle)
        c = Candle.new(open, close, high, low, bar_index, bar_index, bar_index, bar_index, na, na, na)
        bull = c.c > c.o
        c.body      := box.new(bar_index, math.max(c.o,c.c), bar_index+2, math.min(c.o,c.c), bull ? settings.bull_border : settings.bear_border, 1, bgcolor=bull ? settings.bull_body : settings.bear_body)
        c.wick_up   := line.new(bar_index+1, c.h, bar_index, math.max(c.o,c.c), color=bull ? settings.bull_wick : settings.bear_wick)
        c.wick_down := line.new(bar_index+1, math.min(c.o,c.c), bar_index, c.l, color=bull ? settings.bull_wick : settings.bear_wick)
        cs.candles.unshift(c)
        if cs.candles.size() > cs.settings.max_display
            d = cs.candles.pop()
            d.body.delete() 
            d.wick_up.delete() 
            d.wick_down.delete()
    cs

method Update(CandleSet cs, int offset, bool showTrace) =>
    if cs.candles.size() > 0
        c    = cs.candles.first()
        c.h_idx := high  > c.h ? bar_index : c.h_idx 
        c.h := high  > c.h ? high  : c.h
        c.l_idx := low   < c.l ? bar_index : c.l_idx 
        c.l := low   < c.l ? low   : c.l
        c.c := close 
        c.c_idx := bar_index
        bull = c.c > c.o
        c.body.set_top(c.o) 
        c.body.set_bottom(c.c)
        c.body.set_bgcolor(bull ? settings.bull_body : settings.bear_body)
        c.body.set_border_color(bull ? settings.bull_border : settings.bear_border)
        c.wick_up.set_color(bull ? settings.bull_wick : settings.bear_wick)
        c.wick_down.set_color(bull ? settings.bull_wick : settings.bear_wick)
        c.wick_up.set_y1(c.h)   
        c.wick_up.set_y2(math.max(c.o,c.c))
        c.wick_down.set_y1(c.l) 
        c.wick_down.set_y2(math.min(c.o,c.c))
        if barstate.isrealtime or barstate.islast
            cs.Reorder(offset)
            if settings.trace_show and showTrace
                if bar_index - c.o_idx < 5000
                    if na(trace.o) 
                        trace.o := line.new(c.o_idx, c.o, c.body.get_left(), c.o, xloc=xloc.bar_index, color=settings.trace_o_color, style=helper.LineStyle(settings.trace_o_style), width=settings.trace_o_size)
                    else           
                        trace.o.set_xy1(c.o_idx, c.o) 
                        trace.o.set_xy2(c.body.get_left(), c.o)
                    if settings.label_show
                        if na(trace.o_l) 
                            trace.o_l := label.new(c.body.get_right(), c.o, str.tostring(c.o), textalign=text.align_center, style=label.style_label_left, size=settings.label_size, color=color_transparent, textcolor=settings.label_color)
                        else             
                            trace.o_l.set_xy(c.body.get_right(), c.o) 
                            trace.o_l.set_text(str.tostring(c.o))
                if bar_index - c.c_idx < 5000
                    if na(trace.c) 
                        trace.c := line.new(c.c_idx, c.c, c.body.get_left(), c.c, xloc=xloc.bar_index, color=settings.trace_c_color, style=helper.LineStyle(settings.trace_c_style), width=settings.trace_c_size)
                    else           
                        trace.c.set_xy1(c.c_idx, c.c) 
                        trace.c.set_xy2(c.body.get_left(), c.c)
                    if settings.label_show
                        if na(trace.c_l) 
                            trace.c_l := label.new(c.body.get_right(), c.c, str.tostring(c.c), textalign=text.align_center, style=label.style_label_left, size=settings.label_size, color=color_transparent, textcolor=settings.label_color)
                        else             
                            trace.c_l.set_xy(c.body.get_right(), c.c) 
                            trace.c_l.set_text(str.tostring(c.c))
                if bar_index - c.h_idx < 5000
                    if na(trace.h) 
                        trace.h := line.new(c.h_idx, c.h, c.wick_up.get_x1(), c.h, xloc=xloc.bar_index, color=settings.trace_h_color, style=helper.LineStyle(settings.trace_h_style), width=settings.trace_h_size)
                    else           
                        trace.h.set_xy1(c.h_idx, c.h) 
                        trace.h.set_xy2(c.wick_up.get_x1(), c.h)
                    if settings.label_show
                        if na(trace.h_l) 
                            trace.h_l := label.new(c.body.get_right(), c.h, str.tostring(c.h), textalign=text.align_center, style=label.style_label_left, size=settings.label_size, color=color_transparent, textcolor=settings.label_color)
                        else             
                            trace.h_l.set_xy(c.body.get_right(), c.h) 
                            trace.h_l.set_text(str.tostring(c.h))
                if bar_index - c.l_idx < 5000
                    if na(trace.l) 
                        trace.l := line.new(c.l_idx, c.l, c.wick_down.get_x1(), c.l, xloc=xloc.bar_index, color=settings.trace_l_color, style=helper.LineStyle(settings.trace_l_style), width=settings.trace_l_size)
                    else           
                        trace.l.set_xy1(c.l_idx, c.l) 
                        trace.l.set_xy2(c.wick_down.get_x1(), c.l)
                    if settings.label_show
                        if na(trace.l_l) 
                            trace.l_l := label.new(c.body.get_right(), c.l, str.tostring(c.l), textalign=text.align_center, style=label.style_label_left, size=settings.label_size, color=color_transparent, textcolor=settings.label_color)
                        else             
                            trace.l_l.set_xy(c.body.get_right(), c.l) 
                            trace.l_l.set_text(str.tostring(c.l))
    cs

// HTF candle dispatch
htf_cnt = 0 
htf_offset = settings.offset 
htf_last = helper.HTFEnabled()

if htf1.settings.show and helper.ValidTimeframe(htf1.settings.htf)
