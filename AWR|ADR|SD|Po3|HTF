pivot_data() =>
    ph = ta.pivothigh(high, leftLen_swing, rightLen_swing)
    pl = ta.pivotlow(low,  leftLen_swing, rightLen_swing)
    [ph, pl, time[rightLen_swing]]

[ph_htf, pl_htf, ptime_htf] = request.security(syminfo.tickerid, swing_tf, pivot_data(), gaps=barmerge.gaps_on)

var int dayCount_swing = 0
if ta.change(time('D')) != 0 
    dayCount_swing += 1

wipe_swings() =>
    if activeHighs.size() > 0
        for i = activeHighs.size() - 1 to 0
            activeHighs.get(i).ln.delete()
        activeHighs.clear()
    if activeLows.size() > 0
        for i = activeLows.size() - 1 to 0
            activeLows.get(i).ln.delete()
        activeLows.clear()
    if mitigatedHighs.size() > 0
        for i = mitigatedHighs.size() - 1 to 0
            mitigatedHighs.get(i).ln.delete()
        mitigatedHighs.clear()
    if mitigatedLows.size() > 0
        for i = mitigatedLows.size() - 1 to 0
            mitigatedLows.get(i).ln.delete()
        mitigatedLows.clear()

if not show_swings or swing_days_limit == 0
    wipe_swings()
else
    if not na(ph_htf)
