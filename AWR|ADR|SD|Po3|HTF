            hz.LN.unshift(line.new(bar_index, open, bar_index, open, style=hz_style, width=hz_width, color=col))
            hz.LB.unshift(label.new(bar_index, open, txt_l, style=label.style_label_left, color=transparent, textcolor=txt_color, size=lbl_size))
