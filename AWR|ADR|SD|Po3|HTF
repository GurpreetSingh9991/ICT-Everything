type FVG
    box   b
    float top
    float bot
    bool  isBull

var array<FVG> activeFVGs = array.new<FVG>()

fvg_data() =>
    bull_fvg = (low > high[2] and close[1] > open[1]) ? 1.0 : na
    bear_fvg = (high < low[2] and close[1] < open[1]) ? 1.0 : na
    [bull_fvg, bear_fvg, low, high[2], low[2], high, time[2], time]

[bull_fvg, bear_fvg, t_bull, b_bull, t_bear, b_bear, fvg_t1, fvg_t2] = request.security(syminfo.tickerid, fvg_tf, fvg_data(), gaps=barmerge.gaps_on)

if show_fvg
    if not na(bull_fvg)
        bx = box.new(left=fvg_t1, top=t_bull, right=fvg_t2, bottom=b_bull, xloc=xloc.bar_time, border_color=color.new(color.black,100), bgcolor=fvg_bull_col)
        activeFVGs.push(FVG.new(bx, t_bull, b_bull, false))
        if activeFVGs.size() > fvg_limit
            d = activeFVGs.shift() 
            d.b.delete()
    if not na(bear_fvg)
        bx = box.new(left=fvg_t1, top=t_bear, right=fvg_t2, bottom=b_bear, xloc=xloc.bar_time, border_color=color.new(color.black,100), bgcolor=fvg_bear_col)
        activeFVGs.push(FVG.new(bx, t_bear, b_bear, false))
        if activeFVGs.size() > fvg_limit
            d = activeFVGs.shift() 
            d.b.delete()
    if activeFVGs.size() > 0
        for i = activeFVGs.size() - 1 to 0
            f = activeFVGs.get(i)
            f.b.set_right(time)
            // BUG FIX: delete the box on mitigation (original leaked boxes)
            if f.isBull and low < f.bot
                f.b.delete()
                activeFVGs.remove(i)
            else if not f.isBull and high > f.top
                f.b.delete()
                activeFVGs.remove(i)


